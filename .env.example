# Environment Variables (Optional)
# Copy this file to .env.local and fill in your values if needed

# API Configuration (if you plan to add backend APIs)
# VITE_API_BASE_URL=https://api.unishark.in
# VITE_API_KEY=your_api_key_here

# Analytics (if you add Google Analytics, Mixpanel, etc.)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Feature Flags
# VITE_ENABLE_BETA_FEATURES=false

# Note: Only variables prefixed with VITE_ will be available in the browser
# More info: https://vitejs.dev/guide/env-and-modes.html
